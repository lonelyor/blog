# --- Hugo 核心生成物 (禁止上传，占用空间大) ---
/public/
/resources/_gen/
/hugo_cache/
/static/admin/

# --- 构建锁与临时状态文件 ---
.hugo_build.lock
.hugo_build.temp
hugo_stats.json
assets/jsconfig.json

# --- 脚本与本地自动化工具 ---
# 你提到的格式化脚本，建议留在本地执行
fmt_md.py
*.bak
*.temp

# --- 操作系统与编辑器残留 ---
.DS_Store
Thumbs.db
*.log
# IDE 配置文件 (VS Code / JetBrains)
.vscode/
.idea/

# --- 环境变量与私密信息 ---
.env
config.local.toml